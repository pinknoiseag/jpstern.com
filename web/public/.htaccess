# JP Stern — Statik + Pre-Shoot Schutz
# Nach Deploy: Passwort-Datei anlegen (siehe deploy/README-hostpoint.md)

<IfModule mod_rewrite.c>
RewriteEngine On

# Alte WordPress-URLs → neue Pfade
RewriteRule ^home-hero/?$ / [R=301,L]
RewriteRule ^about-me/?$ /about/ [R=301,L]
RewriteRule ^kontakt/?$ /contact/ [R=301,L]

# SPA-style: existierende Dateien/Ordner direkt ausliefern
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
</IfModule>

# Browser-Cache (ersetzt WP Rocket für Statik)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Pre-Shoot: Basic Auth (optional — .htpasswd auf Hostpoint anlegen)
# <LocationMatch "^/(pre-shoot|pre-shoot-)">
#   AuthType Basic
#   AuthName "Pre-Shoot"
#   AuthUserFile /home/USER/www/jpstern.com/.htpasswd
#   Require valid-user
# </LocationMatch>