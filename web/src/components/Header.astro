---
import { portfolioEntries } from '../data/portfolio';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/faq/', label: 'FAQ' },
  { href: '/contact/', label: 'Kontakt' },
  { href: '/about/', label: 'About Me' },
];

const path = Astro.url.pathname;
const normalizedPath = path.endsWith('/') ? path : `${path}/`;

function isNavActive(href: string): boolean {
  return normalizedPath === href;
}

function isPortfolioActive(): boolean {
  return normalizedPath === '/portfolio/' || normalizedPath.startsWith('/works-');
}

const contact = {
  instagram: 'https://www.instagram.com/jpstern.photography/',
  instagramHandle: '@jpstern.photography',
  email: 'info@jpstern.com',
  phone: '+506 8687 9292',
  whatsapp: 'https://wa.me/50686879292',
  tagline: 'The Traveling Photographer',
};
---

<header class="header">
  <div class="header-inner container">
    <div class="header-top">
      <a href="/" class="logo-link">
        <img src="/images/logo.png" alt="JP Stern Photography" width="320" height="148" />
      </a>

      <div class="header-meta">
        <span class="header-tagline">{contact.tagline}</span>

        <div class="header-icons" aria-label="Kontakt und Social Media">
          <a
            href={contact.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="icon-link"
            aria-label={`Instagram: ${contact.instagramHandle}`}
            title={contact.instagramHandle}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          </a>
          <a href={`mailto:${contact.email}`} class="icon-link" aria-label={`E-Mail: ${contact.email}`} title={contact.email}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z" />
            </svg>
          </a>
          <a
            href={contact.whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="icon-link"
            aria-label={`WhatsApp: ${contact.phone}`}
            title={contact.phone}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1C10.07 21 3 13.93 3 5a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.46.57 3.58a1 1 0 01-.24 1.01l-2.2 2.2z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <nav class="nav" aria-label="Hauptnavigation">
      <a href="/" class:list={['nav-link', { active: isNavActive('/') }]}>Home</a>

      <div class="nav-dropdown" data-nav-dropdown>
        <a
          href="/portfolio/"
          class:list={['nav-link', 'nav-link-parent', { active: isPortfolioActive() }]}
          aria-haspopup="true"
        >
          Portfolio
          <span class="nav-caret" aria-hidden="true" />
        </a>
        <ul class="nav-submenu" role="menu" aria-label="Portfolio Galerien">
          {portfolioEntries.map((entry) => (
            <li role="none">
              <a
                href={entry.href}
                role="menuitem"
                class:list={['nav-sublink', { active: normalizedPath === entry.href }]}
              >
                <span class="nav-sublink-label">{entry.menuLabel}</span>
                <span class="nav-sublink-meta">{entry.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      {nav.slice(1).map((item) => (
        <a href={item.href} class:list={['nav-link', { active: isNavActive(item.href) }]}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const dropdowns = document.querySelectorAll('[data-nav-dropdown]');

  dropdowns.forEach((dropdown) => {
    const parent = dropdown.querySelector('.nav-link-parent');
    if (!parent) return;

    parent.addEventListener('click', (event) => {
      if (window.matchMedia('(max-width: 900px)').matches) {
        event.preventDefault();
        const open = dropdown.classList.toggle('is-open');
        parent.setAttribute('aria-expanded', open ? 'true' : 'false');
      }
    });
  });

  document.addEventListener('click', (event) => {
    dropdowns.forEach((dropdown) => {
      if (!dropdown.contains(event.target as Node)) {
        dropdown.classList.remove('is-open');
        dropdown.querySelector('.nav-link-parent')?.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #000;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .header-inner {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 0.35rem;
    padding: 0.4rem 0 0.5rem;
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    width: 100%;
  }

  .logo-link {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }

  .logo-link img {
    height: 72px;
    width: auto;
    display: block;
  }

  .header-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: flex-end;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.82);
  }

  .header-icons {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .icon-link {
    display: inline-flex;
    color: rgba(255, 255, 255, 0.78);
    transition: color 0.2s;
  }

  .icon-link:hover {
    color: #fff;
  }

  .header-tagline {
    white-space: nowrap;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    width: 100%;
    padding-top: 0.35rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-link {
    font-size: 0.88rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.72);
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: #fff;
  }

  .nav-link.active {
    color: var(--gold);
  }

  .nav-dropdown {
    position: relative;
  }

  /* Unsichtbare Brücke — sonst schliesst das Menü in der Lücke zum Dropdown */
  .nav-dropdown::after {
    content: '';
    position: absolute;
    left: -0.5rem;
    right: -0.5rem;
    top: 100%;
    height: 0.65rem;
  }

  .nav-link-parent {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav-caret {
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid currentColor;
    opacity: 0.7;
    transition: transform 0.2s;
  }

  .nav-submenu {
    list-style: none;
    margin: 0;
    padding: 0.35rem 0;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 11.5rem;
    background: #111;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 10px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.45);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.15s, visibility 0.15s;
    transition-delay: 0s, 0.12s;
    z-index: 120;
  }

  .nav-dropdown:hover .nav-submenu,
  .nav-dropdown:focus-within .nav-submenu,
  .nav-dropdown.is-open .nav-submenu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition-delay: 0s, 0s;
  }

  .nav-dropdown:hover .nav-caret,
  .nav-dropdown:focus-within .nav-caret,
  .nav-dropdown.is-open .nav-caret {
    transform: rotate(180deg);
  }

  .nav-sublink {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding: 0.65rem 1rem;
    color: rgba(255, 255, 255, 0.82);
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .nav-sublink:hover,
  .nav-sublink.active {
    background: rgba(201, 168, 106, 0.1);
    color: var(--gold);
  }

  .nav-sublink-label {
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .nav-sublink-meta {
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.45);
    text-transform: none;
  }

  .nav-sublink:hover .nav-sublink-meta,
  .nav-sublink.active .nav-sublink-meta {
    color: rgba(201, 168, 106, 0.65);
  }

  @media (max-width: 900px) {
    .header-top {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 0.85rem;
    }

    .header-meta {
      justify-content: center;
      gap: 0.75rem;
    }

    .nav {
      gap: 0.85rem 1.25rem;
    }

    .nav-dropdown {
      width: 100%;
      text-align: center;
    }

    .nav-submenu {
      position: static;
      transform: none;
      min-width: 0;
      width: 100%;
      max-width: 14rem;
      margin: 0.35rem auto 0;
      box-shadow: none;
      background: rgba(255, 255, 255, 0.03);
    }

    .nav-dropdown:not(.is-open) .nav-submenu {
      display: none;
    }

    .nav-dropdown.is-open .nav-submenu {
      display: block;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }
  }

  @media (max-width: 520px) {
    .logo-link img {
      height: 64px;
    }

    .header-tagline {
      width: 100%;
      text-align: center;
    }

    .nav {
      gap: 0.65rem 1rem;
    }
  }
</style>