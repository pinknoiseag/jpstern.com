---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description = 'JP Stern — Fine Art Portrait & Sensual Photography. Traveling Photographer based in Sámara, Costa Rica.', noindex = false } = Astro.props;
const fullTitle = title === 'Home' ? 'JP Stern Photography' : `${title} — JP Stern Photography`;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content="https://jpstern.com/images/hero/01.webp" />
    <title>{fullTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'JP Stern',
      jobTitle: 'Photographer',
      url: 'https://jpstern.com',
      email: 'info@jpstern.com',
      sameAs: ['https://www.instagram.com/jpstern.photography/'],
    })} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    flex: 1;
  }
</style>