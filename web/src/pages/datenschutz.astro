---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import LegalProse from '../components/LegalProse.astro';
import { datenschutzSections } from '../data/legal';
---

<Layout
  title="Datenschutz"
  description="Datenschutzerklärung von JP Stern Photography — welche Daten bearbeitet werden und welche Rechte du hast."
>
  <PageHero
    title="Datenschutz"
    subtitle="Transparente Information zur Datenbearbeitung"
    image="/images/hero/02.webp"
  />

  <section class="legal-section">
    <div class="container">
      <LegalProse sections={datenschutzSections} />
      <p class="legal-nav">
        <a href="/impressum/">Impressum</a>
        ·
        <a href="/contact/">Kontakt</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  .legal-section {
    padding: 3rem 0 4.5rem;
  }
  .legal-nav {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    font-size: 0.92rem;
    color: var(--text-muted);
    text-align: center;
  }
  .legal-nav a {
    color: var(--gold);
  }
</style>