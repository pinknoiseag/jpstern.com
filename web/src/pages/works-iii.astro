---
import Layout from '../layouts/Layout.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import manifest from '../data/gallery-manifest.json';

const gallery = manifest.find((g) => g.slug === 'works-iii') ?? {
  title: 'Sensual Nude',
  description: 'Sensual Nude und Art Nude — JP Stern Photography.',
  images: [],
};
---

<Layout title={gallery.title} description={gallery.description ?? 'Portfolio — JP Stern Photography'}>
  <GalleryGrid title={gallery.title} images={gallery.images} galleryId="works-iii" />
</Layout>